# ==========================================
# Flowww AI - Root .gitignore
# ==========================================

# ------------------------------------------
# 1. Next.js Frontend (apps/web)
# ------------------------------------------
# dependencies
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js build output
**/.next/
**/out/
**/build/

# ------------------------------------------
# 2. Python Backend (apps/api)
# ------------------------------------------
# Byte-compiled / optimized / DLL files
**/__pycache__/
**/*.py[cod]
**/*$py.class

# Virtual Environments
**/venv/
**/env/
**/.venv/
**/env.bak/
**/venv.bak/

# ------------------------------------------
# 3. Application Data (CRITICAL)
# ------------------------------------------
# Do not commit the local vector DB or user PDFs!
**/storage/
**/uploads/
**/*.pdf

# ------------------------------------------
# 4. Environment Variables & Secrets
# ------------------------------------------
# Never commit your Groq or Gemini API keys!
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
*.pem

# ------------------------------------------
# 5. OS & IDE Files
# ------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
.idea/
*.swp

# ------------------------------------------
# 6. Deployment / Logs
# ------------------------------------------
.vercel/
*.log